# Polymarket CLOB API credentials (required for live trading)
PRIVATE_KEY=
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=
FUNDER_ADDRESS=
# 0 = EOA, 1 = Polymarket proxy wallet (gas-sponsored), 2 = Gnosis safe
SIGNATURE_TYPE=1
CHAIN_ID=137

# Optional: Builder attribution / relayer signing
# Recommended: remote signer URL (keeps builder secret off bot host)
BUILDER_SIGNER_URL=
BUILDER_SIGNER_TOKEN=
# Alternative: local builder creds (set all 3 together)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Trading mode (default: true = paper trading, set to false for live)
PAPER_TRADE=true
ENABLE_LIVE_ORDERS=false
# Required exact string only when ENABLE_LIVE_ORDERS=true
LIVE_ACKNOWLEDGE=
LIVE_MAX_TRADES_PER_RUN=8
LIVE_MAX_NOTIONAL_USDC=100

# Strategy parameters
EDGE_THRESHOLD=0.20
POSITION_SIZE_USDC=5
MIN_TIME_REMAINING_SEC=60
VOL_WINDOW_SEC=300
MAX_CONCURRENT_POSITIONS=3
MAX_DAILY_LOSS_USDC=100
MIN_NET_EDGE=0.02
MIN_EXPECTED_PNL_USDC=0.05
SLIPPAGE_BUFFER=0.003
SAME_WINDOW_MIN_PRICE_DELTA=0.15
MIN_ENTRY_PRICE=0.30
MAX_ENTRY_PRICE=0.75
MAX_SPREAD=0.08
PROBABILITY_SHRINK=0.85
MIN_PROBABILITY=0.001
MAX_PROBABILITY=0.999
DRIFT_PER_SEC=0
MIN_SIGMA_PER_SEC=0.000005
MAX_SIGMA_PER_SEC=0.005
RATE_LIMIT_COOLDOWN_MS=5000

# Logging: DEBUG, INFO, TRADE, WARN, ERROR
LOG_LEVEL=INFO
