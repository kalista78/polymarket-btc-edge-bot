# Polymarket CLOB API credentials (required for live trading)
PRIVATE_KEY=
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=
FUNDER_ADDRESS=
# 0 = EOA, 1 = Polymarket proxy wallet (gas-sponsored), 2 = Gnosis safe
SIGNATURE_TYPE=1
CHAIN_ID=137

# Optional: Builder attribution / relayer signing
# Recommended: remote signer URL (keeps builder secret off bot host)
BUILDER_SIGNER_URL=
BUILDER_SIGNER_TOKEN=
# Alternative: local builder creds (set all 3 together)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Trading mode (default: true = paper trading, set to false for live)
PAPER_TRADE=true
ENABLE_LIVE_ORDERS=false
# Required exact string only when ENABLE_LIVE_ORDERS=true
LIVE_ACKNOWLEDGE=
LIVE_MAX_TRADES_PER_RUN=8
LIVE_MAX_NOTIONAL_USDC=100

# Portfolio tracking baseline
STARTING_BALANCE_USDC=100

# Telegram alerts + control
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# If true, first chat to send /start or /status gets bound as control chat
TELEGRAM_ALLOW_FIRST_CHAT=false
TELEGRAM_POLL_INTERVAL_MS=3000
TELEGRAM_NOTIFY_ENTRIES=true
TELEGRAM_NOTIFY_RESOLUTIONS=true
TELEGRAM_NOTIFY_CLAIMS=true

# Auto-claim (resolved winnings)
# Requires PAPER_TRADE=false and builder auth for SIGNATURE_TYPE 1/2
AUTO_CLAIM_ENABLED=false
AUTO_CLAIM_INTERVAL_MS=90000
CLAIM_SIZE_THRESHOLD=0
DATA_API_BASE_URL=https://data-api.polymarket.com
RELAYER_URL=https://relayer-v2.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com

# Strategy parameters
# Price signal source for fair-value model + volatility:
# chainlink = Polymarket/Chainlink stream only (recommended)
# binance   = Binance stream only
# auto      = prefer Chainlink, fallback to Binance
PRICE_SOURCE=chainlink
# Max age for signal ticks before trading pauses (ms)
PRICE_STALE_MS=15000
EDGE_THRESHOLD=0.20
POSITION_SIZE_USDC=5
MIN_TIME_REMAINING_SEC=60
VOL_WINDOW_SEC=300
MAX_CONCURRENT_POSITIONS=3
# Set to 0 to disable this cap (bot can keep entering without waiting for resolutions)
MAX_DAILY_LOSS_USDC=100
MAX_ROUND_LOSS_USDC=10
# Auto take-profit on open positions (ROI >= 1.0 means +100%)
TAKE_PROFIT_ENABLED=true
TAKE_PROFIT_ROI=1.0
MIN_NET_EDGE=0.02
MIN_EXPECTED_PNL_USDC=0.05
SLIPPAGE_BUFFER=0.003
# Per-side same-window re-entry gap (7c default). Opposite-side entries are allowed.
SAME_WINDOW_MIN_PRICE_DELTA=0.07
MIN_ENTRY_PRICE=0.30
MAX_ENTRY_PRICE=0.75
MAX_SPREAD=0.08
MIN_BOOK_FILL_RATIO=0.70
MIN_BOOK_DEPTH_USDC=25
PROBABILITY_SHRINK=0.85
MIN_PROBABILITY=0.001
MAX_PROBABILITY=0.999
DRIFT_PER_SEC=0
MIN_SIGMA_PER_SEC=0.000005
MAX_SIGMA_PER_SEC=0.005
ROUND_VOL_BLEND=0.35
ROUND_VOL_FLOOR_MULTIPLIER=0.85
VOL_REGIME_ENABLED=true
VOL_REGIME_LOOKBACK=120
VOL_HIGH_MULTIPLIER=1.8
VOL_LOW_MULTIPLIER=0.7
VOL_HIGH_EDGE_FACTOR=0.90
VOL_LOW_EDGE_FACTOR=1.10
FEE_RATE_BPS=1000

# Late-window (30-60s) high-conviction mode
LATE_WINDOW_ENABLED=true
LATE_WINDOW_MIN_TIME_SEC=30
LATE_WINDOW_MAX_TIME_SEC=60
LATE_WINDOW_MIN_ZSCORE=3.0
LATE_WINDOW_EDGE_THRESHOLD=0.05
LATE_WINDOW_MIN_NET_EDGE=0.01
LATE_WINDOW_SIZE_MULTIPLIER=1.20
LATE_WINDOW_MAX_ENTRY_PRICE=0.90

# Chainlink/Binance confirmation weighting
CHAINLINK_CONFIRM_ENABLED=true
CHAINLINK_CONFIRM_BOOST=0.015
CHAINLINK_CONFLICT_PULL=0.20
CHAINLINK_NEUTRAL_MOVE_BPS=2
CHAINLINK_AGREE_SIZE_MULTIPLIER=1.10
CHAINLINK_DISAGREE_SIZE_MULTIPLIER=0.85

# Adaptive sizing
ADAPTIVE_SIZING_ENABLED=true
MIN_POSITION_SIZE_USDC=5
MAX_POSITION_SIZE_USDC=25
ADAPTIVE_EDGE_MULTIPLIER=6
ADAPTIVE_CONFIDENCE_MULTIPLIER=0.7

# Up+Down combined mispricing detector
COMBINED_ARB_ENABLED=true
COMBINED_ARB_EXECUTE=false
COMBINED_ARB_MIN_NET_PER_SHARE=0.02
COMBINED_ARB_MAX_USDC=6

# Execution behavior (fill-friendly by default)
EXECUTION_ORDER_TYPE=FAK
EXECUTION_MAX_REPRICE_STEPS=1
EXECUTION_REPRICE_STEP=0.01
EXECUTION_PRICE_BUFFER=0.005
MIN_LIVE_FILL_USDC=1.0
RATE_LIMIT_COOLDOWN_MS=5000

# Logging: DEBUG, INFO, TRADE, WARN, ERROR
LOG_LEVEL=INFO
